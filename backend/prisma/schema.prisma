generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ENUMS
//

enum UserRole {
  patient
  doctor
  admin
  receptionist
}

enum Gender {
  M
  F
}

enum AppointmentStatus {
  scheduled
  confirmed
  completed
  cancelled
  no_show
}

//
// MODELS
//

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  email        String    @unique
  passwordHash String
  role         UserRole
  avatarUrl    String?
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())

  patient      Patient?
  doctor       Doctor?
}

model Patient {
  id                   Int       @id @default(autoincrement())
  userId               Int       @unique
  lastName             String
  firstName            String
  middleName           String?
  birthDate            DateTime
  gender               Gender
  phone                String?
  address              String
  medicalCardNumber    String?   @unique
  primaryTherapistId   Int       // обязательный терапевт
  createdAt            DateTime  @default(now())

  user                 User      @relation(fields: [userId], references: [id])
  primaryTherapist     Doctor    @relation("TherapistPatients", fields: [primaryTherapistId], references: [id])

  appointments         Appointment[]
  visits               Visit[]
}

model Doctor {
  id             Int       @id @default(autoincrement())
  userId         Int       @unique
  lastName       String
  firstName      String
  middleName     String?
  specialization String
  isTherapist    Boolean   @default(false)
  photoUrl       String?
  phone          String?
  cabinetId      Int       // врач обязан иметь кабинет
  createdAt      DateTime  @default(now())

  user           User      @relation(fields: [userId], references: [id])
  cabinet        Cabinet   @relation(fields: [cabinetId], references: [id])

  patients       Patient[] @relation("TherapistPatients")
  appointments   Appointment[]
  visits         Visit[]
  serviceAreas   TherapistServiceArea[]
}

model TherapistServiceArea {
  id              Int       @id @default(autoincrement())
  doctorId        Int
  addressPattern  String
  description     String?
  createdAt       DateTime  @default(now())

  doctor          Doctor    @relation(fields: [doctorId], references: [id])
}

model Cabinet {
  id                  Int       @id @default(autoincrement())
  number              String    @unique
  floor               Int?
  workingHoursStart   DateTime  // TIME → DateTime (Prisma не поддерживает TIME)
  workingHoursEnd     DateTime
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())

  doctors             Doctor[]
  appointments        Appointment[]
}

model Appointment {
  id              Int               @id @default(autoincrement())
  patientId       Int
  doctorId        Int
  cabinetId       Int?
  appointmentDate DateTime
  startTime       DateTime
  endTime         DateTime
  status          AppointmentStatus @default(scheduled)
  reason          String?
  createdAt       DateTime          @default(now())

  patient         Patient           @relation(fields: [patientId], references: [id])
  doctor          Doctor            @relation(fields: [doctorId], references: [id])
  cabinet         Cabinet?          @relation(fields: [cabinetId], references: [id])
  visit           Visit?
}

model Visit {
  id              Int       @id @default(autoincrement())
  appointmentId   Int
  patientId       Int
  doctorId        Int
  visitDatetime   DateTime
  complaints      String?
  diagnosis       String?
  examination     String?
  treatment       String?
  recommendations String?
  createdAt       DateTime  @default(now())

  appointment     Appointment @relation(fields: [appointmentId], references: [id])
  patient         Patient     @relation(fields: [patientId], references: [id])
  doctor          Doctor      @relation(fields: [doctorId], references: [id])
  files           AttachedFile[]
}

model AttachedFile {
  id          Int       @id @default(autoincrement())
  visitId     Int
  fileType    String
  description String?
  filePath    String
  uploadedAt  DateTime  @default(now())

  visit       Visit     @relation(fields: [visitId], references: [id])
}
