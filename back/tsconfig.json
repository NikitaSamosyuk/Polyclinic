{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "types": ["node"],
    "ignoreDeprecations": "5.0",
    "lib": ["ES2021"],
    "typeRoots": ["./src/types", "./node_modules/@types"]   // 🔥 ДОБАВЛЕНО
  },
  "include": [
    "src/**/*.ts",
    "prisma/**/*.ts",
    "src/types/**/*.d.ts"   // 🔥 ДОБАВЛЕНО
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts"
  ]
}
