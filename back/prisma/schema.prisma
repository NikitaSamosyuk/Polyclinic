generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DOCTOR
  PATIENT
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  email        String    @unique
  passwordHash String
  role         Role
  avatarUrl    String?
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())

  patient Patient?
  doctor  Doctor?
}

model Patient {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique
  lastName           String
  firstName          String
  middleName         String?
  birthDate          DateTime
  gender             String?
  phone              String?
  address            String?
  medicalCardNumber  String?  @unique
  primaryTherapistId Int?
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  primaryTherapist Doctor? @relation("TherapistPatients", fields: [primaryTherapistId], references: [id])

  appointments Appointment[]
  visits       Visit[]
}

model Doctor {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  lastName       String
  firstName      String
  middleName     String?
  specialization String
  isTherapist    Boolean  @default(false)
  phone          String?
  createdAt      DateTime @default(now())

  photoUrl       String?   // 🔥 ДОБАВЛЕНО — фото доктора

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  cabinetId Int?
  cabinet   Cabinet? @relation(fields: [cabinetId], references: [id])

  patients Patient[] @relation("TherapistPatients")

  appointments Appointment[]
  visits       Visit[]

  addressZones TherapistAddressZone[]
}


model TherapistAddressZone {
  id        Int    @id @default(autoincrement())
  doctorId  Int
  zone      String

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model Cabinet {
  id                Int      @id @default(autoincrement())
  number            String   @unique
  floor             Int?
  specialization    String   // кабинет принимает только врачей этой специальности
  workingHoursStart String
  workingHoursEnd   String
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  // до 2 врачей
  doctors Doctor[]

  appointments Appointment[]
}

model Appointment {
  id              Int      @id @default(autoincrement())
  patientId       Int
  doctorId        Int
  cabinetId       Int
  appointmentDate DateTime
  startTime       DateTime
  endTime         DateTime
  status          String   @default("scheduled")
  reason          String?
  createdAt       DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])
  cabinet Cabinet @relation(fields: [cabinetId], references: [id])
  visit   Visit?
}

model Visit {
  id              Int      @id @default(autoincrement())
  appointmentId   Int      @unique
  patientId       Int
  doctorId        Int
  visitDatetime   DateTime
  complaints      String?
  diagnosis       String?
  examination     String?
  treatment       String?
  recommendations String?
  createdAt       DateTime @default(now())

  appointment   Appointment    @relation(fields: [appointmentId], references: [id])
  patient       Patient        @relation(fields: [patientId], references: [id])
  doctor        Doctor         @relation(fields: [doctorId], references: [id])
  attachedFiles AttachedFile[]
}

model AttachedFile {
  id          Int      @id @default(autoincrement())
  visitId     Int
  fileType    String
  description String?
  filePath    String
  uploadedAt  DateTime @default(now())

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)
}
